generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum SaleChannel {
  DIRECT
  FALABELLA
  MERCADO_LIBRE
  RIPLEY
  CUSTOM

  @@map("sale_channel")
}

enum CostType {
  SUPPLIER
  TRANSPORT
  MARKETPLACE
  ADVERTISING
  OTHER

  @@map("cost_type")
}

model Category {
  id String @id @default(uuid())

  name String @unique

  slug String? @unique

  description String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  products Product[]

  @@index([name])
  @@map("categories")
}

model Supplier {
  id String @id @default(uuid())

  name String @unique

  contactName String?

  phone String?

  email String?

  notes String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  products Product[]

  @@index([name])
  @@map("suppliers")
}

model Product {
  id String @id @default(uuid())

  sku String @unique

  name String

  brand String?

  categoryId String
  supplierId String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  category Category @relation(fields: [categoryId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  saleItems SaleItem[]

  @@index([sku])
  @@index([name])
  @@index([categoryId])
  @@index([supplierId])
  @@map("products")
}

model Sale {
  id String @id @default(uuid())

  saleChannel SaleChannel
  saleDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  items SaleItem[]
  costs SaleCost[]
  profitSnapshot SaleProfitSnapshot?

  @@index([saleDate])
  @@index([saleChannel])
  @@map("sales")
}

model SaleItem {
  id String @id @default(uuid())

  saleId String
  productId String
  quantity Int
  unitPriceGross Decimal @db.Decimal(12, 2)
  unitPriceNet Decimal @db.Decimal(12, 2)
  vatAmount Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model SaleCost {
  id String @id @default(uuid())

  saleId String
  costType CostType
  description String?
  occurredAt DateTime
  costGross Decimal @db.Decimal(12, 2)
  costNet Decimal @db.Decimal(12, 2)
  vatAmount Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  sale Sale @relation(fields: [saleId], references: [id])

  @@index([saleId])
  @@index([costType])
  @@map("sale_costs")
}

model SaleProfitSnapshot {
  saleId String @id

  revenueNet Decimal @db.Decimal(12, 2)
  totalCostNet Decimal @db.Decimal(12, 2)
  profit Decimal @db.Decimal(12, 2)
  marginPercentage Decimal @db.Decimal(5, 2)

  createdAt DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id])

  @@index([profit])
  @@index([marginPercentage])
  @@map("sale_profit_snapshots")
}
